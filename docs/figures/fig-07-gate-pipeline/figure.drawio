<mxfile host="app.diagrams.net" agent="orcast" version="24.0.0">
  <diagram name="7. Gate pipeline" id="gate">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="ORCAST - Gate pipeline: detections to displayed confidence" style="text;html=1;fontStyle=1;fontSize=16;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#2F1F3A;" vertex="1" parent="1"><mxGeometry x="380" y="16" width="640" height="28" as="geometry" /></mxCell>

        <!-- main pipeline -->
        <mxCell id="det" value="Acoustic detections (OrcaHello)" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#1F1426;" vertex="1" parent="1"><mxGeometry x="400" y="60" width="340" height="44" as="geometry" /></mxCell>
        <mxCell id="l0" value="&lt;b&gt;L0 QC quarantine&lt;/b&gt;&lt;br&gt;unreviewed stream isolated" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#1F1426;" vertex="1" parent="1"><mxGeometry x="400" y="124" width="340" height="50" as="geometry" /></mxCell>
        <mxCell id="psth" value="&lt;b&gt;PSTH kernel fit&lt;/b&gt;&lt;br&gt;logλ(x,t) = b0 + Σ βk·φk(t) + logE  (E1)" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#1F1426;" vertex="1" parent="1"><mxGeometry x="400" y="194" width="340" height="50" as="geometry" /></mxCell>
        <mxCell id="gnull" value="&lt;b&gt;Phase-shuffled null test&lt;/b&gt;&lt;br&gt;p_null = P(T(shuffled) &gt;= T(obs))  (E2)" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#1F1426;" vertex="1" parent="1"><mxGeometry x="400" y="264" width="340" height="50" as="geometry" /></mxCell>
        <mxCell id="gof" value="&lt;b&gt;Time-rescaling GoF KS test&lt;/b&gt;&lt;br&gt;τi = Λ(ti) - Λ(ti-1) ~ Exp(1)  (E3)" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#1F1426;" vertex="1" parent="1"><mxGeometry x="400" y="334" width="340" height="50" as="geometry" /></mxCell>
        <mxCell id="cv" value="&lt;b&gt;Held-out deviance skill&lt;/b&gt;&lt;br&gt;S_D = 1 - D_model / D_null  (E5)" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#1F1426;" vertex="1" parent="1"><mxGeometry x="400" y="404" width="340" height="50" as="geometry" /></mxCell>
        <mxCell id="pit" value="&lt;b&gt;PIT calibration KS test&lt;/b&gt;&lt;br&gt;ui = F_model(yi) ~ Uniform(0,1)  (E6)" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#1F1426;" vertex="1" parent="1"><mxGeometry x="400" y="474" width="340" height="50" as="geometry" /></mxCell>
        <mxCell id="ceff" value="&lt;b&gt;Effective confidence&lt;/b&gt;&lt;br&gt;c_eff = c_raw · Π gk  (E4)" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=11;fillColor=#D9C2EA;strokeColor=#A86FB2;fontColor=#1F1426;" vertex="1" parent="1"><mxGeometry x="400" y="544" width="340" height="50" as="geometry" /></mxCell>
        <mxCell id="human" value="&lt;b&gt;Human promotion&lt;/b&gt;&lt;br&gt;signed decision record - DynamoDB" style="rounded=12;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontStyle=1;fontSize=11;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#1F1426;" vertex="1" parent="1"><mxGeometry x="400" y="624" width="340" height="56" as="geometry" /></mxCell>

        <!-- IC stubs (right) -->
        <mxCell id="ic1" value="&lt;b&gt;IC: no signal&lt;/b&gt;&lt;br&gt;&lt;i&gt;Kernel contributes nothing; confidence unchanged&lt;/i&gt;" style="rounded=2;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;fillColor=#FCEFD9;strokeColor=#C98A2E;fontColor=#5E4218;" vertex="1" parent="1"><mxGeometry x="840" y="264" width="300" height="50" as="geometry" /></mxCell>
        <mxCell id="ic2" value="&lt;b&gt;IC: GoF failed&lt;/b&gt;&lt;br&gt;&lt;i&gt;Model does not fit temporal spike train&lt;/i&gt;" style="rounded=2;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;fillColor=#FCEFD9;strokeColor=#C98A2E;fontColor=#5E4218;" vertex="1" parent="1"><mxGeometry x="840" y="334" width="300" height="50" as="geometry" /></mxCell>
        <mxCell id="ic3" value="&lt;b&gt;IC: skill negative&lt;/b&gt;&lt;br&gt;&lt;i&gt;Model worse than null on held-out data&lt;/i&gt;" style="rounded=2;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;fillColor=#FCEFD9;strokeColor=#C98A2E;fontColor=#5E4218;" vertex="1" parent="1"><mxGeometry x="840" y="404" width="300" height="50" as="geometry" /></mxCell>
        <mxCell id="ic4" value="&lt;b&gt;IC: miscalibrated&lt;/b&gt;&lt;br&gt;&lt;i&gt;ui not ~ Uniform(0,1); PIT fails&lt;/i&gt;" style="rounded=2;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=10;spacingLeft=6;fillColor=#FCEFD9;strokeColor=#C98A2E;fontColor=#5E4218;" vertex="1" parent="1"><mxGeometry x="840" y="474" width="300" height="50" as="geometry" /></mxCell>

        <!-- Gate PASS (left) -->
        <mxCell id="pass" value="&lt;b&gt;Gate PASS: all ICs clear&lt;/b&gt;&lt;br&gt;c_eff = c_raw&lt;br&gt;(no gate reduced confidence)" style="rounded=2;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=10;fillColor=#DDF0DD;strokeColor=#5AA15A;fontColor=#234A23;" vertex="1" parent="1"><mxGeometry x="60" y="529" width="280" height="80" as="geometry" /></mxCell>

        <!-- legend -->
        <mxCell id="legend" value="Failing a gate surfaces an integrity condition alongside the metric. It does &lt;i&gt;not&lt;/i&gt; suppress the forecast. The human promotion step is the final gate before confidence is raised. E1-E6: equation labels from the whitepaper." style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=10;spacingLeft=8;spacingRight=8;fillColor=#FAF7FC;strokeColor=#A86FB2;fontColor=#1F1426;" vertex="1" parent="1"><mxGeometry x="60" y="708" width="1080" height="56" as="geometry" /></mxCell>

        <!-- pipeline edges -->
        <mxCell id="ge1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="det" target="l0"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="l0" target="psth"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="psth" target="gnull"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge4" value="pass: p &lt; α" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontSize=9;fontColor=#5AA15A;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="gnull" target="gof"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge5" value="pass: KS ok" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontSize=9;fontColor=#5AA15A;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="gof" target="cv"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge6" value="pass: S_D &gt; 0" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontSize=9;fontColor=#5AA15A;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="cv" target="pit"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge7" value="pass: calibrated" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontSize=9;fontColor=#5AA15A;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="pit" target="ceff"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ge8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ceff" target="human"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- fail stubs -->
        <mxCell id="gf1" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;endFill=1;strokeColor=#C98A2E;fontSize=9;fontColor=#C98A2E;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="gnull" target="ic1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gf2" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;endFill=1;strokeColor=#C98A2E;fontSize=9;fontColor=#C98A2E;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="gof" target="ic2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gf3" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;endFill=1;strokeColor=#C98A2E;fontSize=9;fontColor=#C98A2E;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="cv" target="ic3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gf4" value="fail" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;endFill=1;strokeColor=#C98A2E;fontSize=9;fontColor=#C98A2E;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="pit" target="ic4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- IC returns to c_eff via right channel -->
        <mxCell id="gr1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;endFill=1;strokeColor=#C98A2E;exitX=1;exitY=0.5;entryX=1;entryY=0.35;" edge="1" parent="1" source="ic1" target="ceff"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1175" y="289" /><mxPoint x="1175" y="561" /></Array></mxGeometry></mxCell>
        <mxCell id="gr2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;endFill=1;strokeColor=#C98A2E;exitX=1;exitY=0.5;entryX=1;entryY=0.45;" edge="1" parent="1" source="ic2" target="ceff"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1185" y="359" /><mxPoint x="1185" y="567" /></Array></mxGeometry></mxCell>
        <mxCell id="gr3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;endFill=1;strokeColor=#C98A2E;exitX=1;exitY=0.5;entryX=1;entryY=0.55;" edge="1" parent="1" source="ic3" target="ceff"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1165" y="429" /><mxPoint x="1165" y="572" /></Array></mxGeometry></mxCell>
        <mxCell id="gr4" value="reduce c_eff" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;endFill=1;strokeColor=#C98A2E;fontSize=9;fontColor=#C98A2E;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;entryX=1;entryY=0.65;" edge="1" parent="1" source="ic4" target="ceff"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1155" y="499" /><mxPoint x="1155" y="577" /></Array></mxGeometry></mxCell>

        <!-- Gate PASS to c_eff -->
        <mxCell id="gpass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;endArrow=block;endFill=1;strokeColor=#5AA15A;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="pass" target="ceff"><mxGeometry relative="1" as="geometry" /></mxCell>

