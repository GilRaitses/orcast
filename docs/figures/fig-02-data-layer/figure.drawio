<mxfile host="app.diagrams.net" agent="orcast" version="24.0.0">
  <diagram name="2. Data layer (S3 + adapters)" id="data">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="d_title" value="ORCAST - Data layer: source adapters, S3 buckets, DynamoDB, and fitted models" style="text;html=1;fontStyle=1;fontSize=18;align=left;verticalAlign=middle;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="40" y="24" width="980" height="30" as="geometry" /></mxCell>
        <mxCell id="d_note" value="Workflow sprint sync - manifests + versioned artifacts - 2026-06-21" style="text;html=1;fontSize=11;align=right;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="1100" y="27" width="420" height="24" as="geometry" /></mxCell>

        <mxCell id="src" value="&lt;b&gt;External sources&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;OrcaHello acoustic detections&lt;br&gt;NOAA CO-OPS water level/currents&lt;br&gt;Salmon Albion / DART counts&lt;br&gt;Orcasound hydrophone uptime&lt;br&gt;OBIS and iNaturalist sightings&lt;br&gt;&lt;br&gt;Network sources with source links when available" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#A86FB2;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="260" height="216" as="geometry" /></mxCell>

        <mxCell id="source_adapters" value="&lt;b&gt;Source-linked adapters&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;OrcaHelloHistoryAdapter&lt;br&gt;NoaaAdapter&lt;br&gt;SalmonRunAdapter&lt;br&gt;OrcasoundAdapter&lt;br&gt;LiveObisAdapter&lt;br&gt;INaturalistAdapter&lt;br&gt;CommunitySubmissionAdapter&lt;br&gt;&lt;br&gt;set source_url / evidence_urls only when source links exist" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="340" y="90" width="300" height="215" as="geometry" /></mxCell>

        <mxCell id="raw_bucket" value="&lt;b&gt;Raw payloads + time-series S3&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;raw/{run_id}/{source}/*.json&lt;br&gt;timeseries/{stream}/{station}/{YYYY}/{MM}.ndjson&lt;br&gt;snapshots/{snap_id}/manifest.json&lt;br&gt;fit_plans/{fit_plan_id}/fit_plan.json&lt;br&gt;&lt;br&gt;streams: acoustic, currents, water level, salmon, uptime" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#A86FB2;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="710" y="80" width="400" height="195" as="geometry" /></mxCell>

        <mxCell id="ddb" value="&lt;b&gt;DynamoDB writes&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;sightings&lt;br&gt;ingestion-runs&lt;br&gt;reports metadata&lt;br&gt;decision-records&lt;br&gt;&lt;br&gt;See Page 1 for table detail" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#A86FB2;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="710" y="335" width="400" height="145" as="geometry" /></mxCell>

        <mxCell id="fit" value="&lt;b&gt;Fit container Lambda&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;modeling/ container&lt;br&gt;creates fit_plan + snap_id&lt;br&gt;builds design matrix&lt;br&gt;negative-binomial LNP fit&lt;br&gt;fitness gates + confidence" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="1260" y="120" width="290" height="155" as="geometry" /></mxCell>

        <mxCell id="models" value="&lt;b&gt;Fitted artifacts / models S3&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;models/current.json&lt;br&gt;representations/{repr_id}/fitted_kernels.json&lt;br&gt;representations/{repr_id}/representation.json&lt;br&gt;runs/{run_id}/fit_report.json&lt;br&gt;runs/{run_id}/manifest.json&lt;br&gt;models/promotion.json&lt;br&gt;models/pending_approval.json (server token only)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#A86FB2;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="1260" y="315" width="290" height="185" as="geometry" /></mxCell>

        <mxCell id="static_geo" value="&lt;b&gt;Static local data&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;data/geo&lt;br&gt;bathymetry / coastal geography&lt;br&gt;&lt;br&gt;Local/static read, not a streaming external source" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#A86FB2;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="40" y="390" width="260" height="125" as="geometry" /></mxCell>

        <mxCell id="bath_adapter" value="&lt;b&gt;BathymetryAdapter&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;reads data/geo&lt;br&gt;adds static spatial features&lt;br&gt;no blanket source_url claim" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="340" y="395" width="300" height="115" as="geometry" /></mxCell>

        <mxCell id="report_writer" value="&lt;b&gt;Report writer&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;scheduled report / API path&lt;br&gt;uses sightings, source status, hotspots, and model version&lt;br&gt;stores report body outside DynamoDB" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#E8DDF4;strokeColor=#A86FB2;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="710" y="565" width="400" height="120" as="geometry" /></mxCell>

        <mxCell id="reports_bucket" value="&lt;b&gt;Reports S3 bucket&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;ORCAST_REPORTS_BUCKET&lt;br&gt;reports/{id}.json&lt;br&gt;&lt;br&gt;Separate report documents bucket" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#A86FB2;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="1260" y="575" width="290" height="110" as="geometry" /></mxCell>

        <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;Solid filled arrow: data flow direction&lt;br&gt;Dashed filled arrow: optional/manual read path&lt;br&gt;No FK or crow-foot notation on this flow page" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#A86FB2;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="40" y="735" width="420" height="95" as="geometry" /></mxCell>

        <mxCell id="e1" value="fetch + normalize" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="src" target="source_adapters"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="writes raw + series" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="source_adapters" target="raw_bucket"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="writes DynamoDB" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="source_adapters" target="ddb"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="675" y="198" /><mxPoint x="675" y="408" /></Array></mxGeometry></mxCell>
        <mxCell id="e4" value="reads time-series" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="raw_bucket" target="fit"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="writes repr_id/run_id artifacts" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fit" target="models"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="reads local static data" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="static_geo" target="bath_adapter"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="static features" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="bath_adapter" target="fit"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="675" y="452" /><mxPoint x="675" y="198" /></Array></mxGeometry></mxCell>
        <mxCell id="e8" value="reads metadata" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ddb" target="report_writer"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="reads model version" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontColor=#222222;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="models" target="report_writer"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1405" y="525" /><mxPoint x="910" y="525" /></Array></mxGeometry></mxCell>
        <mxCell id="e10" value="writes report body" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#A86FB2;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="report_writer" target="reports_bucket"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
