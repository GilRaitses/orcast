          <mxCell id="me_resume_wait" value="resumes AwaitHumanDecision" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="1" source="task_resume" target="s_wait"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1085" y="650" /><mxPoint x="1085" y="480" /></Array></mxGeometry></mxCell>
