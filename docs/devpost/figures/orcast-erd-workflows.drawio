  <diagram name="4. Request + Auth flow" id="auth">
      <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="850" math="0" shadow="0">
        <root>
          <mxCell id="0" />
          <mxCell id="1" parent="0" />
  
          <mxCell id="title" value="ORCAST - Page 4: Request + Auth Flow" style="text;html=1;fontStyle=1;fontSize=18;fontColor=#2f2440;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="24" width="620" height="30" as="geometry" /></mxCell>
          <mxCell id="version" value="Wave 1 remediation - 2026-06-21 - public reads remain open; reviewer actions and PII require WorkOS session" style="text;html=1;fontSize=11;fontColor=#6f5d7d;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="42" y="52" width="860" height="24" as="geometry" /></mxCell>
  
          <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;solid arrow: request / data flow&lt;br&gt;purple: public read path&lt;br&gt;dark purple: authenticated reviewer path&lt;br&gt;dashed arrow: browser redirect through hosted AuthKit" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#ffffff;strokeColor=#9b6bb3;" vertex="1" parent="1"><mxGeometry x="1035" y="28" width="300" height="124" as="geometry" /></mxCell>
  
          <mxCell id="browser" value="&lt;b&gt;Browser&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;viewer: forecast, gates, provenance&lt;br&gt;reviewer: moderation, decisions&lt;br&gt;returns from /callback with session cookie" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#ffffff;strokeColor=#9b6bb3;" vertex="1" parent="1"><mxGeometry x="55" y="142" width="245" height="118" as="geometry" /></mxCell>
  
          <mxCell id="web" value="&lt;b&gt;Vercel Next.js web&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;/login, /signup, /callback&lt;br&gt;/api/be/[...path] server proxy&lt;br&gt;AuthKit middleware validates session&lt;br&gt;browser never sees X-ORCAST-Key" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#f7f1fb;strokeColor=#9b6bb3;" vertex="1" parent="1"><mxGeometry x="390" y="132" width="290" height="136" as="geometry" /></mxCell>
  
          <mxCell id="authkit" value="&lt;b&gt;Hosted WorkOS AuthKit&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;runs on *.authkit.app&lt;br&gt;browser redirects there directly&lt;br&gt;providers: email + social login&lt;br&gt;success redirects back to /callback" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#f7f1fb;strokeColor=#9b6bb3;" vertex="1" parent="1"><mxGeometry x="750" y="132" width="270" height="136" as="geometry" /></mxCell>
  
          <mxCell id="public_lane" value="Public reads" style="swimlane;html=1;startSize=30;fontStyle=1;fontColor=#4f2d63;fillColor=#fbf8fd;strokeColor=#c6a7d8;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="55" y="315" width="585" height="165" as="geometry" /></mxCell>
          <mxCell id="public_get" value="&lt;b&gt;Public GET allow-list&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;forecast + map reads&lt;br&gt;/api/gates summaries&lt;br&gt;/api/provenance read views&lt;br&gt;rate limited by /api/be" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#ffffff;strokeColor=#9b6bb3;" vertex="1" parent="public_lane"><mxGeometry x="25" y="55" width="245" height="96" as="geometry" /></mxCell>
          <mxCell id="public_proxy" value="&lt;b&gt;/api/be public branch&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;GET path matches allow-list&lt;br&gt;no WorkOS session required&lt;br&gt;server may forward backend key&lt;br&gt;per-IP rate limit applies" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#ffffff;strokeColor=#9b6bb3;" vertex="1" parent="public_lane"><mxGeometry x="315" y="55" width="245" height="96" as="geometry" /></mxCell>
  
          <mxCell id="auth_lane" value="Authenticated reviewer actions" style="swimlane;html=1;startSize=30;fontStyle=1;fontColor=#2f2440;fillColor=#f3e8fa;strokeColor=#8f5aa8;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="55" y="520" width="585" height="198" as="geometry" /></mxCell>
          <mxCell id="review_actions" value="&lt;b&gt;Reviewer actions + PII&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;POST /api/decision-records&lt;br&gt;POST /api/promotion/*&lt;br&gt;community moderation updates&lt;br&gt;PII-bearing submission reads" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#ffffff;strokeColor=#8f5aa8;" vertex="1" parent="auth_lane"><mxGeometry x="25" y="55" width="245" height="116" as="geometry" /></mxCell>
          <mxCell id="secure_proxy" value="&lt;b&gt;/api/be protected branch&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;requires WorkOS withAuth()&lt;br&gt;checks session before forwarding&lt;br&gt;injects X-ORCAST-Key only server-side&lt;br&gt;per-IP rate limit still applies" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#ffffff;strokeColor=#8f5aa8;" vertex="1" parent="auth_lane"><mxGeometry x="315" y="55" width="245" height="116" as="geometry" /></mxCell>
  
          <mxCell id="fastapi" value="&lt;b&gt;AWS App Runner - FastAPI&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;serves /forecast/* and /api/provenance&lt;br&gt;serves /api/gates via serve.py&lt;br&gt;handles sightings, community, decisions&lt;br&gt;write paths require API key from proxy" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#f7f1fb;strokeColor=#9b6bb3;" vertex="1" parent="1"><mxGeometry x="760" y="372" width="305" height="138" as="geometry" /></mxCell>
  
          <mxCell id="dynamo" value="&lt;b&gt;DynamoDB&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;sightings, reports, hotspots&lt;br&gt;community submissions&lt;br&gt;decision-records&lt;br&gt;ingestion-runs" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#ffffff;strokeColor=#9b6bb3;" vertex="1" parent="1"><mxGeometry x="1140" y="315" width="205" height="116" as="geometry" /></mxCell>
          <mxCell id="s3" value="&lt;b&gt;S3&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;reports/{id}.json&lt;br&gt;time-series NDJSON&lt;br&gt;models/* fitted artifacts&lt;br&gt;raw payload snapshots" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#ffffff;strokeColor=#9b6bb3;" vertex="1" parent="1"><mxGeometry x="1140" y="498" width="205" height="116" as="geometry" /></mxCell>
          <mxCell id="models_note" value="&lt;b&gt;/api/gates / serve.py&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;reads models/* from S3&lt;br&gt;returns gate status, caveats,&lt;br&gt;confidence, promotion metadata" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontColor=#2f2440;fillColor=#fbf8fd;strokeColor=#9b6bb3;" vertex="1" parent="1"><mxGeometry x="805" y="595" width="265" height="105" as="geometry" /></mxCell>
  
          <mxCell id="e_browser_web" value="HTTPS app routes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#4f2d63;strokeColor=#9b6bb3;endArrow=block;endFill=1;" edge="1" parent="1" source="browser" target="web"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e_web_authkit" value="redirect to *.authkit.app" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#4f2d63;strokeColor=#9b6bb3;dashed=1;endArrow=block;endFill=1;" edge="1" parent="1" source="web" target="authkit"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e_authkit_browser" value="302 back to /callback" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#4f2d63;strokeColor=#9b6bb3;dashed=1;endArrow=block;endFill=1;" edge="1" parent="1" source="authkit" target="browser"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1035" y="220" /><mxPoint x="1035" y="95" /><mxPoint x="175" y="95" /></Array></mxGeometry></mxCell>
  
          <mxCell id="e_web_public" value="public GET" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#4f2d63;strokeColor=#9b6bb3;endArrow=block;endFill=1;" edge="1" parent="1" source="web" target="public_get"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="535" y="295" /><mxPoint x="205" y="295" /></Array></mxGeometry></mxCell>
          <mxCell id="e_public_proxy" value="allow-list + rate limit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#4f2d63;strokeColor=#9b6bb3;endArrow=block;endFill=1;" edge="1" parent="public_lane" source="public_get" target="public_proxy"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e_public_api" value="forward read request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#4f2d63;strokeColor=#9b6bb3;endArrow=block;endFill=1;" edge="1" parent="1" source="public_proxy" target="fastapi"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="665" y="418" /></Array></mxGeometry></mxCell>
  
          <mxCell id="e_web_review" value="mutation / PII" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#2f2440;strokeColor=#6f3f86;endArrow=block;endFill=1;" edge="1" parent="1" source="web" target="review_actions"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="535" y="500" /><mxPoint x="205" y="500" /></Array></mxGeometry></mxCell>
          <mxCell id="e_review_proxy" value="WorkOS session required" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#2f2440;strokeColor=#6f3f86;endArrow=block;endFill=1;" edge="1" parent="auth_lane" source="review_actions" target="secure_proxy"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e_secure_api" value="server adds X-ORCAST-Key" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#2f2440;strokeColor=#6f3f86;endArrow=block;endFill=1;" edge="1" parent="1" source="secure_proxy" target="fastapi"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="665" y="632" /><mxPoint x="710" y="632" /><mxPoint x="710" y="455" /></Array></mxGeometry></mxCell>
  
          <mxCell id="e_api_dynamo" value="reads / writes app records" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#4f2d63;strokeColor=#9b6bb3;endArrow=block;endFill=1;" edge="1" parent="1" source="fastapi" target="dynamo"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e_api_s3" value="reads reports, time-series, artifacts" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#4f2d63;strokeColor=#9b6bb3;endArrow=block;endFill=1;" edge="1" parent="1" source="fastapi" target="s3"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e_gates_s3" value="reads models/*" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontColor=#4f2d63;strokeColor=#9b6bb3;endArrow=block;endFill=1;" edge="1" parent="1" source="models_note" target="s3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1075" y="648" /><mxPoint x="1110" y="648" /><mxPoint x="1110" y="556" /></Array></mxGeometry></mxCell>
