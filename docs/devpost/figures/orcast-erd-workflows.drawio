  <diagram name="2. Data layer (S3 + adapters)" id="data">
      <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
        <root>
          <mxCell id="0" />
          <mxCell id="1" parent="0" />
  
          <mxCell id="d_title" value="ORCAST - Data layer: source adapters, S3 buckets, DynamoDB, and fitted models" style="text;html=1;fontStyle=1;fontSize=18;align=left;verticalAlign=middle;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="40" y="24" width="980" height="30" as="geometry" /></mxCell>
          <mxCell id="d_note" value="Workflow sprint sync - manifests + versioned artifacts - 2026-06-21" style="text;html=1;fontSize=11;align=right;verticalAlign=middle;fontColor=#666666;" vertex="1" parent="1"><mxGeometry x="1100" y="27" width="420" height="24" as="geometry" /></mxCell>
  
          <mxCell id="src" value="&lt;b&gt;External sources&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;OrcaHello acoustic detections&lt;br&gt;NOAA CO-OPS water level/currents&lt;br&gt;Salmon Albion / DART counts&lt;br&gt;Orcasound hydrophone uptime&lt;br&gt;OBIS and iNaturalist sightings&lt;br&gt;&lt;br&gt;Network sources with source links when available" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="40" y="100" width="260" height="185" as="geometry" /></mxCell>
  
          <mxCell id="source_adapters" value="&lt;b&gt;Source-linked adapters&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;OrcaHelloHistoryAdapter&lt;br&gt;NoaaAdapter&lt;br&gt;SalmonRunAdapter&lt;br&gt;OrcasoundAdapter&lt;br&gt;LiveObisAdapter&lt;br&gt;INaturalistAdapter&lt;br&gt;CommunitySubmissionAdapter&lt;br&gt;&lt;br&gt;set source_url / evidence_urls only when source links exist" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="340" y="90" width="300" height="215" as="geometry" /></mxCell>
  
          <mxCell id="raw_bucket" value="&lt;b&gt;Raw payloads + time-series S3&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;raw/{run_id}/{source}/*.json&lt;br&gt;timeseries/{stream}/{station}/{YYYY}/{MM}.ndjson&lt;br&gt;snapshots/{snap_id}/manifest.json&lt;br&gt;fit_plans/{fit_plan_id}/fit_plan.json&lt;br&gt;&lt;br&gt;streams: acoustic, currents, water level, salmon, uptime" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="710" y="80" width="400" height="195" as="geometry" /></mxCell>
  
          <mxCell id="ddb" value="&lt;b&gt;DynamoDB writes&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;sightings&lt;br&gt;ingestion-runs&lt;br&gt;reports metadata&lt;br&gt;decision-records&lt;br&gt;&lt;br&gt;See Page 1 for table detail" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="710" y="335" width="400" height="145" as="geometry" /></mxCell>
  
          <mxCell id="fit" value="&lt;b&gt;Fit container Lambda&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;modeling/ container&lt;br&gt;creates fit_plan + snap_id&lt;br&gt;builds design matrix&lt;br&gt;negative-binomial LNP fit&lt;br&gt;fitness gates + confidence" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="1260" y="120" width="290" height="155" as="geometry" /></mxCell>
  
          <mxCell id="models" value="&lt;b&gt;Fitted artifacts / models S3&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;models/current.json&lt;br&gt;representations/{repr_id}/fitted_kernels.json&lt;br&gt;representations/{repr_id}/representation.json&lt;br&gt;runs/{run_id}/fit_report.json&lt;br&gt;runs/{run_id}/manifest.json&lt;br&gt;models/promotion.json&lt;br&gt;models/pending_approval.json (server token only)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="1260" y="315" width="290" height="185" as="geometry" /></mxCell>
  
          <mxCell id="static_geo" value="&lt;b&gt;Static local data&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;data/geo&lt;br&gt;bathymetry / coastal geography&lt;br&gt;&lt;br&gt;Local/static read, not a streaming external source" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="40" y="390" width="260" height="125" as="geometry" /></mxCell>
  
          <mxCell id="bath_adapter" value="&lt;b&gt;BathymetryAdapter&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;reads data/geo&lt;br&gt;adds static spatial features&lt;br&gt;no blanket source_url claim" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="340" y="395" width="300" height="115" as="geometry" /></mxCell>
  
          <mxCell id="report_writer" value="&lt;b&gt;Report writer&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;scheduled report / API path&lt;br&gt;uses sightings, source status, hotspots, and model version&lt;br&gt;stores report body outside DynamoDB" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="710" y="565" width="400" height="120" as="geometry" /></mxCell>
  
          <mxCell id="reports_bucket" value="&lt;b&gt;Reports S3 bucket&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;ORCAST_REPORTS_BUCKET&lt;br&gt;reports/{id}.json&lt;br&gt;&lt;br&gt;Separate report documents bucket" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="1260" y="575" width="290" height="110" as="geometry" /></mxCell>
  
          <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;Solid filled arrow: data flow direction&lt;br&gt;Dashed filled arrow: optional/manual read path&lt;br&gt;No FK or crow-foot notation on this flow page" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=7;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#222222;" vertex="1" parent="1"><mxGeometry x="40" y="735" width="420" height="95" as="geometry" /></mxCell>
  
          <mxCell id="e1" value="fetch + normalize" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="src" target="source_adapters"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e2" value="writes raw + series" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="source_adapters" target="raw_bucket"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e3" value="writes DynamoDB" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="source_adapters" target="ddb"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="675" y="198" /><mxPoint x="675" y="408" /></Array></mxGeometry></mxCell>
          <mxCell id="e4" value="reads time-series" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="raw_bucket" target="fit"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e5" value="writes repr_id/run_id artifacts" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="fit" target="models"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e6" value="reads local static data" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="static_geo" target="bath_adapter"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e7" value="static features" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="bath_adapter" target="fit"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="675" y="452" /><mxPoint x="675" y="198" /></Array></mxGeometry></mxCell>
          <mxCell id="e8" value="reads metadata" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ddb" target="report_writer"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="e9" value="reads model version" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#222222;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="models" target="report_writer"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1405" y="525" /><mxPoint x="910" y="525" /></Array></mxGeometry></mxCell>
          <mxCell id="e10" value="writes report body" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#222222;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="report_writer" target="reports_bucket"><mxGeometry relative="1" as="geometry" /></mxCell>
        </root>
      </mxGraphModel>
    </diagram>

  <diagram name="3. Workflows" id="workflows">
      <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
        <root>
          <mxCell id="0" />
          <mxCell id="1" parent="0" />
  
          <mxCell id="w_title" value="ORCAST - Page 3: Workflows" style="text;html=1;fontStyle=1;fontSize=22;fontColor=#1f1f1f;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="50" y="26" width="430" height="34" as="geometry" /></mxCell>
          <mxCell id="w_version" value="Workflow sprint sync - identity, dossier, manifests - 2026-06-21" style="text;html=1;fontSize=12;fontColor=#666666;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="52" y="62" width="720" height="24" as="geometry" /></mxCell>
  
          <mxCell id="sched_group" value="Scheduled workflows" style="swimlane;html=1;startSize=28;fillColor=#fbf8fd;strokeColor=#9673a6;fontColor=#1f1f1f;fontStyle=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="50" y="110" width="650" height="130" as="geometry" /></mxCell>
          <mxCell id="eb_ingest" value="EventBridge&#10;rate(30 min)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="sched_group"><mxGeometry x="25" y="52" width="125" height="50" as="geometry" /></mxCell>
          <mxCell id="lambda_ingest" value="&lt;b&gt;ScheduledIngestion Lambda&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;POST /api/sightings/ingest&lt;br&gt;POST /api/timeseries/refresh" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="sched_group"><mxGeometry x="205" y="42" width="250" height="70" as="geometry" /></mxCell>
          <mxCell id="eb_report" value="EventBridge&#10;rate(1 hour)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="sched_group"><mxGeometry x="495" y="52" width="125" height="50" as="geometry" /></mxCell>
  
          <mxCell id="report_group" value="Report refresh" style="swimlane;html=1;startSize=28;fillColor=#fbf8fd;strokeColor=#9673a6;fontColor=#1f1f1f;fontStyle=1;align=left;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="735" y="110" width="385" height="130" as="geometry" /></mxCell>
          <mxCell id="lambda_report" value="&lt;b&gt;ScheduledReport Lambda&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;recompute hotspots&lt;br&gt;write latest report artifact" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="report_group"><mxGeometry x="32" y="42" width="255" height="70" as="geometry" /></mxCell>
  
          <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;Solid filled arrow: Step Functions execution&lt;br&gt;Dashed filled arrow: manual resume or error path&lt;br&gt;Gate labels describe configured routing&lt;br&gt;No FK or crow-foot notation on this page" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="1"><mxGeometry x="1160" y="110" width="370" height="130" as="geometry" /></mxCell>
  
          <mxCell id="edge_sched_ingest" value="triggers" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="sched_group" source="eb_ingest" target="lambda_ingest"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="edge_sched_report" value="triggers" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="1" source="eb_report" target="lambda_report"><mxGeometry relative="1" as="geometry" /></mxCell>
  
          <mxCell id="sf_lane" value="Step Functions: forecast-orchestrator" style="swimlane;html=1;startSize=32;fillColor=#fbf8fd;strokeColor=#9673a6;fontColor=#1f1f1f;fontStyle=1;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="50" y="285" width="1480" height="335" as="geometry" /></mxCell>
          <mxCell id="s_ingest" value="&lt;b&gt;Ingest&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;refresh sources" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=top;spacingTop=8;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="sf_lane"><mxGeometry x="32" y="72" width="145" height="72" as="geometry" /></mxCell>
          <mxCell id="s_fit" value="&lt;b&gt;FitAndGate&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;fit_plan + snap_id&lt;br&gt;NB fit + gates&lt;br&gt;repr_id + run_id" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=top;spacingTop=8;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="sf_lane"><mxGeometry x="230" y="62" width="170" height="92" as="geometry" /></mxCell>
          <mxCell id="s_gate" value="configured&#10;gate threshold?" style="rhombus;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="sf_lane"><mxGeometry x="455" y="58" width="150" height="100" as="geometry" /></mxCell>
          <mxCell id="s_draft" value="&lt;b&gt;DraftPromotion&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;Bedrock supervisor&lt;br&gt;deterministic fallback" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=top;spacingTop=8;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="sf_lane"><mxGeometry x="675" y="62" width="180" height="92" as="geometry" /></mxCell>
          <mxCell id="s_wait" value="&lt;b&gt;AwaitHumanDecision&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;.waitForTaskToken&lt;br&gt;token stays server-side&lt;br&gt;public gates are redacted" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=top;spacingTop=8;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="sf_lane"><mxGeometry x="930" y="62" width="190" height="92" as="geometry" /></mxCell>
          <mxCell id="s_verdict" value="verdict is&#10;promote?" style="rhombus;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="sf_lane"><mxGeometry x="1190" y="58" width="145" height="100" as="geometry" /></mxCell>
          <mxCell id="s_apply" value="&lt;b&gt;ApplyPromotion&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;requires decision_id&lt;br&gt;writes promotion marker" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=top;spacingTop=8;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;fontSize=11;" vertex="1" parent="sf_lane"><mxGeometry x="1350" y="62" width="118" height="92" as="geometry" /></mxCell>
          <mxCell id="s_hold" value="&lt;b&gt;Hold&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;keep forecast broad&lt;br&gt;await better evidence" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=top;spacingTop=8;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="sf_lane"><mxGeometry x="675" y="225" width="180" height="78" as="geometry" /></mxCell>
          <mxCell id="fit_error" value="&lt;b&gt;FitAndGate Catch/Retry&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;retry transient S3/fit errors&lt;br&gt;catch writes error summary -&gt; Hold" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;dashed=1;" vertex="1" parent="sf_lane"><mxGeometry x="225" y="218" width="245" height="78" as="geometry" /></mxCell>
          <mxCell id="gate_note" value="Current fitted confidence is about 0.5; depending on the configured threshold, this may route to Hold." style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacingLeft=8;fillColor=#fbf8fd;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="sf_lane"><mxGeometry x="455" y="218" width="185" height="78" as="geometry" /></mxCell>
  
          <mxCell id="se_ingest_fit" value="run fit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="sf_lane" source="s_ingest" target="s_fit"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="se_fit_gate" value="gates summary" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="sf_lane" source="s_fit" target="s_gate"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="se_gate_draft" value="passes gate" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="sf_lane" source="s_gate" target="s_draft"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="se_gate_hold" value="below threshold" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="sf_lane" source="s_gate" target="s_hold"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="530" y="195" /><mxPoint x="765" y="195" /></Array></mxGeometry></mxCell>
          <mxCell id="se_draft_wait" value="draft + task token" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="sf_lane" source="s_draft" target="s_wait"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="se_wait_verdict" value="resume verdict" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="sf_lane" source="s_wait" target="s_verdict"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="se_verdict_apply" value="promote" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="sf_lane" source="s_verdict" target="s_apply"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="se_verdict_hold" value="hold / reject / timeout" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="sf_lane" source="s_verdict" target="s_hold"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1262" y="265" /><mxPoint x="855" y="265" /></Array></mxGeometry></mxCell>
          <mxCell id="se_fit_error" value="catch/retry" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="sf_lane" source="s_fit" target="fit_error"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="se_error_hold" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="sf_lane" source="fit_error" target="s_hold"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="348" y="315" /><mxPoint x="765" y="315" /></Array></mxGeometry></mxCell>
  
          <mxCell id="manual_lane" value="Manual reviewer path" style="swimlane;html=1;startSize=30;fillColor=#fbf8fd;strokeColor=#9673a6;fontColor=#1f1f1f;fontStyle=1;align=left;spacingLeft=12;" vertex="1" parent="1"><mxGeometry x="350" y="675" width="870" height="150" as="geometry" /></mxCell>
          <mxCell id="reviewer" value="Reviewer UI&#10;WorkOS session&#10;/gates + /decisions" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="manual_lane"><mxGeometry x="32" y="50" width="145" height="70" as="geometry" /></mxCell>
          <mxCell id="decision_api" value="&lt;b&gt;/api/decision-records&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;reviewer verdict + reason&lt;br&gt;server stamps gates + WorkOS identity" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="manual_lane"><mxGeometry x="245" y="46" width="245" height="78" as="geometry" /></mxCell>
          <mxCell id="task_resume" value="&lt;b&gt;Dossier + task resume&lt;/b&gt;&lt;hr size=&quot;1&quot;&gt;/api/review-dossier/* export&lt;br&gt;SendTaskSuccess(decision_id, verdict)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffffff;strokeColor=#9673a6;fontColor=#1f1f1f;" vertex="1" parent="manual_lane"><mxGeometry x="565" y="46" width="270" height="78" as="geometry" /></mxCell>
          <mxCell id="me_reviewer_api" value="POST verdict" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="manual_lane" source="reviewer" target="decision_api"><mxGeometry relative="1" as="geometry" /></mxCell>
          <mxCell id="me_api_resume" value="uses task token" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#9673a6;fontColor=#6b4f7a;" edge="1" parent="manual_lane" source="decision_api" target="task_resume"><mxGeometry relative="1" as="geometry" /></mxCell>
