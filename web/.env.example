# Backend (App Runner) base URL, used server-side by the proxy route.
ORCAST_API_BASE=https://your-app-runner-host

# Shared API key for keyed endpoints (moderation, promotion, orchestrator run).
# Server-only: never exposed to the browser.
ORCAST_API_KEY=

# --- WorkOS AuthKit (hosted user login) ---
# These gate protected proxy requests (mutations + PII reads) behind a real
# WorkOS user session. Real values are set in Vercel, never committed.

# WorkOS API key (server-only, never exposed to the browser).
WORKOS_API_KEY=

# WorkOS client ID (server-only).
WORKOS_CLIENT_ID=

# Password used to encrypt the session cookie. Must be >= 32 characters.
WORKOS_COOKIE_PASSWORD=

# Redirect URI registered in the WorkOS dashboard. Public (NEXT_PUBLIC_).
NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://orcast-h0.vercel.app/callback

# Server-side automation (Cursor agent / CI). Injected as reviewer identity by the
# /api/be proxy when X-ORCAST-Agent-Key matches. Never expose to the browser.
ORCAST_AGENT_KEY=
ORCAST_AGENT_REVIEWER_ID=agent_orcast_automation
ORCAST_AGENT_REVIEWER_EMAIL=agent@orcast.dev

# Partner API (external agents — Claude/OpenAI/MCP)
ORCAST_PARTNER_DEV_KEY=

# Vercel AI Gateway (exploration guide — generation only; tools on App Runner)
AI_GATEWAY_API_KEY=
ORCAST_EXPLORE_GATEWAY_MODEL=anthropic/claude-haiku-4.5
ORCAST_EXPLORE_GATEWAY_MODELS=anthropic/claude-haiku-4.5,anthropic/claude-sonnet-4.5

# Default managed-agent id used by the interactions route (has a code default).
ORCAST_DEFAULT_AGENT_ID=explore-guide-v1

NEXT_PUBLIC_MAPS_KEY=
