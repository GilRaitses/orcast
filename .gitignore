# Vercel
.vercel

# Logs
logs
*.log
__pycache__/
*.py[cod]
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*
firebase-debug.*.log*

# Firebase cache
.firebase/

# Firebase config

# Uncomment this if you'd like others to create their own Firebase project.
# For a team working on the same Firebase project(s), it is recommended to leave
# it commented so all members can deploy to the same project(s) in .firebaserc.
# .firebaserc

# Firebase service account credentials (security sensitive)
*firebase-adminsdk*.json
config/*firebase-adminsdk*.json

# Google Cloud service account credentials (security sensitive)
config/*-*.json
config/orca-*.json
*.serviceaccount.json
*-service-account*.json

# Other sensitive config files
config/*.env
config/*credentials*
config/*secret*
config/*key*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.agent-credentials.env

# dataconnect generated files
.dataconnect

# Cypress video files (too large for git)
**/cypress/videos/*.mp4
cypress/videos/
orcast-angular/cypress/videos/

# AWS deployment state backups (manifest is kept; timestamped backups are local)
infra/aws/state/backups/

# Local demo server pid
demo/.demo-server.pid
.venv-modeling/
.venv-tts/
venv/
.venv/

# Committed secrets removed from tracking (keep local copies only)
config.js
src/frontend/production_config.js
config/redis_connection.env
