# orcast co-tenant service env TEMPLATE (names only; no secrets committed).
# The real file lives at /opt/orcast/infra/shared_host/env/orcast-services.env
# on the host (chmod 600, owned by the orcast service user) and is injected
# out-of-band from the App Runner RuntimeEnvironmentVariables. NEVER commit the
# filled file. Mirrors arn:aws:apprunner:us-west-2:198456344617:service/orcast-aws-backend.

AWS_REGION=us-west-2
ORCAST_ENV=production
ORCAST_STORAGE_BACKEND=aws

# Secret: must equal the Vercel proxy X-ORCAST-Key (ORCAST_API_KEY).
ORCAST_API_KEY=

ORCAST_CORS_ORIGINS=https://orcast.org,https://www.orcast.org,https://orcast-h0.vercel.app,https://d2gslju5drx74c.cloudfront.net

# DynamoDB tables (us-west-2)
ORCAST_SIGHTINGS_TABLE=orcast-aws-backend-sightings
ORCAST_HOTSPOTS_TABLE=orcast-aws-backend-hotspots
ORCAST_REPORTS_TABLE=orcast-aws-backend-reports
ORCAST_INGESTION_RUNS_TABLE=orcast-aws-backend-ingestion-runs
ORCAST_COMMUNITY_TABLE=orcast-aws-backend-community-submissions
ORCAST_DECISION_RECORDS_TABLE=orcast-aws-backend-decision-records
ORCAST_JOURNAL_TABLE=orcast-aws-backend-user-journal
ORCAST_MANAGED_AGENTS_TABLE=orcast-aws-backend-managed-agents
ORCAST_PARTNER_KEYS_TABLE=orcast-aws-backend-partner-api-keys

# S3 buckets (us-west-2)
ORCAST_REPORTS_BUCKET=198456344617-us-west-2-orcast-aws-backend-reports
ORCAST_RAW_PAYLOAD_BUCKET=198456344617-us-west-2-orcast-aws-backend-raw-payloads

# Step Functions + Bedrock
ORCAST_STATE_MACHINE_ARN=arn:aws:states:us-west-2:198456344617:stateMachine:orcast-aws-backend-forecast-orchestrator
ORCAST_ENABLE_BEDROCK=true
ORCAST_BEDROCK_SIGHTING_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0

# Live source toggles
ORCAST_ENABLE_LIVE_INATURALIST=true
ORCAST_ENABLE_LIVE_NOAA=true
ORCAST_ENABLE_ORCAHELLO=true

# RDS explore (PRIVATE per SD-A07; unreachable from this host's region/VPC).
# Set for parity; explore-session persistence degrades exactly as on App Runner.
ORCAST_DB_HOST=orcast-aws-backend-explore.cjymkcu2uzi1.us-west-2.rds.amazonaws.com
ORCAST_DB_NAME=orcast_explore
ORCAST_DB_USER=orcast
ORCAST_DB_PASSWORD=
ORCAST_EXPLORE_MAX_SESSIONS_PER_IP_DAY=20
ORCAST_EXPLORE_MAX_TURNS_PER_SESSION=30
ORCAST_EXPLORE_RETENTION_DAYS=30
