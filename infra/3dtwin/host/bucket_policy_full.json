{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCloudFront3dtwinPilotReadOnly",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudfront.amazonaws.com"
      },
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::aimez-data/3dtwin/pilot/*",
      "Condition": {
        "StringEquals": {
          "AWS:SourceArn": "arn:aws:cloudfront::198456344617:distribution/EOMERK64CS5CE"
        }
      }
    },
    {
      "Sid": "AllowCloudFront3dtwinFullReadOnly",
      "Effect": "Allow",
      "Principal": {
        "Service": "cloudfront.amazonaws.com"
      },
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::aimez-data/3dtwin/full/*",
      "Condition": {
        "StringEquals": {
          "AWS:SourceArn": "arn:aws:cloudfront::198456344617:distribution/EOMERK64CS5CE"
        }
      }
    }
  ]
}
